# .gitignore file in the repository directory

# Compiled class files
*.class

# Log files
*.log

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Specific hidden metadata MacOS file
.DS_Store

# Temporary backup files, ends with Tilde
*~ 

# Swap files created by vi/vim editor
*.swp
